# ============================================================
# SCANIX BODY — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in the values.
# Never commit .env.local to version control.
# ============================================================

# ------------------------------------------------------------
# Supabase — Required
# Get these from: https://app.supabase.com/project/<id>/settings/api
# ------------------------------------------------------------

# Your Supabase project URL (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anon / public key (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service-role key — NEVER expose this to the browser.
# Used only in server-side code / API routes / Server Actions.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ------------------------------------------------------------
# Database — Required for Prisma / direct DB access (optional)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Supabase connection pooler (Transaction mode, port 6543) is
# recommended for serverless deployments.
# ------------------------------------------------------------
DATABASE_URL=postgresql://postgres:your-password@db.your-project-id.supabase.co:6543/postgres?pgbouncer=true
DATABASE_DIRECT_URL=postgresql://postgres:your-password@db.your-project-id.supabase.co:5432/postgres

# ------------------------------------------------------------
# Application
# ------------------------------------------------------------

# Canonical URL of the deployed app (no trailing slash).
# Used for absolute URL generation, OG images, redirects, etc.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Application environment
NODE_ENV=development

# ------------------------------------------------------------
# Authentication — Optional (if using NextAuth.js alongside Supabase Auth)
# Generate a secret with: openssl rand -base64 32
# ------------------------------------------------------------
# NEXTAUTH_SECRET=your-nextauth-secret-here
# NEXTAUTH_URL=http://localhost:3000

# ------------------------------------------------------------
# AI Features — Optional
# Used for workout plan generation, nutrition analysis, etc.
# Get your key from: https://platform.openai.com/api-keys
# ------------------------------------------------------------
# OPENAI_API_KEY=sk-your-openai-api-key-here
# OPENAI_ORG_ID=org-your-org-id-here

# ------------------------------------------------------------
# Analytics — Optional
# ------------------------------------------------------------
# NEXT_PUBLIC_POSTHOG_KEY=phc_your-posthog-key
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ------------------------------------------------------------
# Storage — Optional (if using a separate storage provider)
# By default Supabase Storage is used.
# ------------------------------------------------------------
# CLOUDFLARE_R2_ACCOUNT_ID=
# CLOUDFLARE_R2_ACCESS_KEY_ID=
# CLOUDFLARE_R2_SECRET_ACCESS_KEY=
# CLOUDFLARE_R2_BUCKET_NAME=scanix-body-assets
# NEXT_PUBLIC_CDN_URL=https://cdn.yourdomain.com
