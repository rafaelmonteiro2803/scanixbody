# ============================================================
# MY APP — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in the values.
# Never commit .env.local to version control.
# ============================================================

# ------------------------------------------------------------
# Supabase — Required
# Get these from: https://app.supabase.com/project/<id>/settings/api
# ------------------------------------------------------------

# Your Supabase project URL (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anon / public key (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service-role key — NEVER expose this to the browser.
# Used only in server-side code / API routes / Server Actions.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ------------------------------------------------------------
# Database — Optional (for direct DB access or migrations)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Supabase connection pooler (Transaction mode, port 6543) is
# recommended for serverless deployments.
# ------------------------------------------------------------
DATABASE_URL=postgresql://postgres:your-password@db.your-project-id.supabase.co:6543/postgres?pgbouncer=true
DATABASE_DIRECT_URL=postgresql://postgres:your-password@db.your-project-id.supabase.co:5432/postgres

# ------------------------------------------------------------
# Application
# ------------------------------------------------------------

# Canonical URL of the deployed app (no trailing slash).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Application environment
NODE_ENV=development

# ------------------------------------------------------------
# AI Features — Optional
# TODO: Add your AI provider key if using AI features.
# ------------------------------------------------------------
# OPENAI_API_KEY=sk-your-openai-api-key-here

# ------------------------------------------------------------
# Analytics — Optional
# TODO: Add your analytics provider keys.
# ------------------------------------------------------------
# NEXT_PUBLIC_POSTHOG_KEY=phc_your-posthog-key
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ------------------------------------------------------------
# Storage — Optional (Supabase Storage is used by default)
# TODO: Switch to a CDN/R2 bucket if needed for large assets.
# ------------------------------------------------------------
# CLOUDFLARE_R2_ACCOUNT_ID=
# CLOUDFLARE_R2_ACCESS_KEY_ID=
# CLOUDFLARE_R2_SECRET_ACCESS_KEY=
# CLOUDFLARE_R2_BUCKET_NAME=my-app-assets
# NEXT_PUBLIC_CDN_URL=https://cdn.yourdomain.com

# ------------------------------------------------------------
# Email — Optional (Supabase SMTP or external provider)
# TODO: Configure SMTP for custom transactional emails.
# ------------------------------------------------------------
# SMTP_HOST=smtp.yourdomain.com
# SMTP_PORT=587
# SMTP_USER=no-reply@yourdomain.com
# SMTP_PASS=your-smtp-password
